    # Шаг 4: Клонируем репозиторий KinoVibe через Secrets
from google.colab import userdata
import os

# Сначала добавь GITHUB_TOKEN в "Secrets" (иконка ключа слева)
try:
    GIT_TOKEN = userdata.get('GITHUB_TOKEN')
    GIT_USER = "vaalchik-lang"
    GIT_REPO = "KinoVibe_Pro" # Уточнил название из прошлых логов
    REPO_URL = f"https://{GIT_TOKEN}@github.com/{GIT_USER}/{GIT_REPO}.git"

    !git clone {REPO_URL} /content/KINOVIBE -q
    %cd /content/KINOVIBE/client
    print(f'✅ Репозиторий {GIT_REPO} клонирован')
except:
    print('❌ Ошибка: Добавь GITHUB_TOKEN в Secrets!')
# Шаг 5: Исправление структуры и сборка APK
print('🔄 Подготовка проекта...')
!flutter clean -q
!flutter pub get -q

# КЛЮЧЕВОЙ МОМЕНТ: Пересоздаем файлы Android, чтобы избежать ошибки "unsupported Gradle project"
!flutter create . --platforms android -v

print('🏗️ Начинаю сборку APK (это может занять 5-7 минут)...')
!flutter build apk --release --no-pub

# Проверка результата
import os
if os.path.exists('build/app/outputs/flutter-apk/app-release.apk'):
    print('✅ APK успешно собран!')
else:
    print('❌ Сборка не удалась. Ищи ошибку в логах выше.')
